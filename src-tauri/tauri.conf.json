{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Conversor de Unidades",
  "version": "0.1.0",
  "identifier": "com.units-conversor.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Conversor de Unidades",
        "width": 800,
        "height": 600,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32.png",
      "icons/64.png",
      "icons/128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
